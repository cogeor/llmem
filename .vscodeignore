# VS Code Extension Package Ignore

# Development files
.vscode/**
.gitignore
tsconfig.json
plan/**
*.log
.github/**
.env
.env.example
scripts/**
.artifacts/**
.arch/**

# Source files (we include dist/ instead)
src/**

# Exclude TypeScript source files
**/*.ts

# Development artifacts
*.vsix

# Exclude all node_modules (not needed in VSIX; vsce bundles deps)
node_modules/**

# MCP server CLI (not needed inside VSIX)
dist/claude/**

# Delegate work folder
.delegate/**

# Per-target tsconfig files
tsconfig.*.json
