{
  "binary": "llmem",
  "commands": [
    {
      "args": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "open": {
            "default": true,
            "type": "boolean"
          },
          "port": {
            "default": 3000,
            "maximum": 65535,
            "minimum": 0,
            "type": "integer"
          },
          "regenerate": {
            "default": false,
            "type": "boolean"
          },
          "verbose": {
            "default": false,
            "type": "boolean"
          },
          "workspace": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "Start HTTP server for webview (default)",
      "examples": [
        {
          "command": "llmem serve",
          "scenario": "Open the viewer in your browser"
        },
        {
          "command": "llmem serve --port 8080 --no-open",
          "scenario": "Use port 8080 without opening a browser"
        },
        {
          "command": "llmem serve --regenerate",
          "scenario": "Force re-scan and regenerate before serving"
        }
      ],
      "name": "serve"
    },
    {
      "args": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {},
        "type": "object"
      },
      "description": "Start MCP server for Claude Code (stdio)",
      "examples": [
        {
          "command": "llmem mcp",
          "scenario": "Start the MCP stdio server (Claude Code config target)"
        }
      ],
      "name": "mcp"
    },
    {
      "args": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "json": {
            "default": false,
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "description": "Print the machine-readable command schema (--json) or a human tree.",
      "examples": [
        {
          "command": "llmem describe",
          "scenario": "Print the human-readable command tree"
        },
        {
          "command": "llmem describe --json",
          "scenario": "Emit the full JSON schema for agent integration"
        }
      ],
      "name": "describe"
    },
    {
      "args": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "folder": {
            "default": ".",
            "description": "Workspace-relative folder to scan (defaults to the whole workspace)",
            "type": "string"
          },
          "workspace": {
            "description": "Workspace root directory (auto-detected if omitted)",
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "Scan the workspace and write edge lists to .artifacts/",
      "examples": [
        {
          "command": "llmem scan",
          "scenario": "Index the entire workspace"
        },
        {
          "command": "llmem scan --folder src/parser",
          "scenario": "Index a single folder"
        }
      ],
      "name": "scan"
    },
    {
      "args": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "_": {
            "description": "(internal) Positional arguments routed by the dispatcher.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "content": {
            "description": "Inline JSON payload — the agent's report_file_info / report_folder_info body.",
            "type": "string"
          },
          "contentFile": {
            "description": "Path to a file containing the JSON payload, or \"-\" to read stdin to EOF.",
            "type": "string"
          },
          "path": {
            "description": "Workspace-relative path to a file or folder to document (positional accepted).",
            "type": "string"
          },
          "promptOnly": {
            "default": false,
            "description": "Print the LLM prompt to stdout and exit 0.",
            "type": "boolean"
          },
          "workspace": {
            "description": "Workspace root directory (auto-detected if omitted).",
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "Generate the LLM prompt or save an LLM-enriched design doc for a file or folder.",
      "examples": [
        {
          "command": "llmem document src/parser/extractor.ts --prompt-only",
          "scenario": "Print the file documentation prompt"
        },
        {
          "command": "llmem document src/parser --prompt-only",
          "scenario": "Print the folder documentation prompt"
        },
        {
          "command": "llmem document src/parser/extractor.ts --content-file -",
          "scenario": "Pipe the agent's JSON output back to write .arch/src/parser/extractor.ts.md"
        }
      ],
      "name": "document"
    },
    {
      "args": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "force": {
            "default": false,
            "description": "Overwrite an existing .llmem/config.toml",
            "type": "boolean"
          },
          "workspace": {
            "description": "Workspace root directory (auto-detected if omitted)",
            "type": "string"
          }
        },
        "type": "object"
      },
      "description": "Write the .llmem/config.toml stub (no-op if it already exists, --force overwrites).",
      "examples": [
        {
          "command": "llmem init",
          "scenario": "Create the config stub in the current workspace"
        },
        {
          "command": "llmem init --force",
          "scenario": "Overwrite an existing stub"
        }
      ],
      "name": "init"
    }
  ],
  "version": "<X>"
}
